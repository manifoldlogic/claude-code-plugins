{
  "version": "1.0",
  "tiers": {
    "core": {
      "description": "Always generated. Cannot be skipped.",
      "documents": ["analysis", "architecture", "plan"]
    },
    "standard": {
      "description": "Generated by default. Can be N/A-signed by planner.",
      "documents": ["prd", "quality-strategy", "security-review"]
    },
    "conditional": {
      "description": "Generated only when trigger criteria match or override.",
      "documents": ["observability", "migration-plan", "accessibility", "api-contract", "runbook", "dependency-audit"]
    }
  },
  "documents": {
    "analysis": {
      "filename": "analysis.md",
      "title": "Problem Analysis",
      "tier": "core",
      "template": "analysis.md",
      "create_tasks_validation": "none"
    },
    "architecture": {
      "filename": "architecture.md",
      "title": "Solution Architecture",
      "tier": "core",
      "template": "architecture.md",
      "create_tasks_validation": "required"
    },
    "plan": {
      "filename": "plan.md",
      "title": "Execution Plan",
      "tier": "core",
      "template": "plan.md",
      "create_tasks_validation": "required"
    },
    "prd": {
      "filename": "prd.md",
      "title": "Product Requirements",
      "tier": "standard",
      "template": "prd.md",
      "create_tasks_validation": "recommended",
      "triggers": {
        "keywords": ["user", "feature", "requirement", "interface", "experience", "workflow", "persona"],
        "description": "Tickets with user-facing features or requirement-heavy scope"
      }
    },
    "quality-strategy": {
      "filename": "quality-strategy.md",
      "title": "Quality Strategy",
      "tier": "standard",
      "template": "quality-strategy.md",
      "create_tasks_validation": "recommended",
      "triggers": {
        "keywords": ["test", "quality", "coverage", "regression", "ci", "pipeline"],
        "description": "Tickets with significant testing concerns"
      }
    },
    "security-review": {
      "filename": "security-review.md",
      "title": "Security Review",
      "tier": "standard",
      "template": "security-review.md",
      "create_tasks_validation": "none",
      "triggers": {
        "keywords": ["auth", "security", "credential", "permission", "secret", "token", "encrypt", "vulnerability", "injection", "input validation"],
        "description": "Tickets touching authentication, authorization, or data security"
      }
    },
    "observability": {
      "filename": "observability.md",
      "title": "Observability Plan",
      "tier": "conditional",
      "template": "observability.md",
      "create_tasks_validation": "none",
      "triggers": {
        "keywords": ["monitor", "metric", "log", "alert", "dashboard", "trace", "observ", "production", "deploy", "service", "api", "backend", "infrastructure"],
        "description": "Tickets deploying services, APIs, or infrastructure that need production visibility"
      }
    },
    "migration-plan": {
      "filename": "migration-plan.md",
      "title": "Migration Plan",
      "tier": "conditional",
      "template": "migration-plan.md",
      "create_tasks_validation": "none",
      "triggers": {
        "keywords": ["migrat", "schema", "database", "rollback", "backward compat", "breaking change", "feature flag", "data model", "rename", "deprecat"],
        "description": "Tickets changing data schemas, APIs with existing consumers, or requiring rollback strategies"
      }
    },
    "accessibility": {
      "filename": "accessibility.md",
      "title": "Accessibility Review",
      "tier": "conditional",
      "template": "accessibility.md",
      "create_tasks_validation": "none",
      "triggers": {
        "keywords": ["ui", "frontend", "user interface", "component", "form", "button", "modal", "dialog", "page", "screen", "wcag", "a11y", "accessible"],
        "description": "Tickets with user-facing UI changes"
      }
    },
    "api-contract": {
      "filename": "api-contract.md",
      "title": "API Contract",
      "tier": "conditional",
      "template": "api-contract.md",
      "create_tasks_validation": "none",
      "triggers": {
        "keywords": ["api", "endpoint", "rest", "graphql", "grpc", "request", "response", "schema", "payload", "contract", "versioning", "openapi", "swagger"],
        "description": "Tickets where the API is the deliverable or existing APIs are modified"
      }
    },
    "runbook": {
      "filename": "runbook.md",
      "title": "Operational Runbook",
      "tier": "conditional",
      "template": "runbook.md",
      "create_tasks_validation": "none",
      "triggers": {
        "keywords": ["deploy", "infrastructure", "service", "production", "incident", "on-call", "rollback", "failover", "scaling", "ops", "devops"],
        "description": "Tickets deploying services or infrastructure that on-call teams need to support"
      }
    },
    "dependency-audit": {
      "filename": "dependency-audit.md",
      "title": "Dependency Audit",
      "tier": "conditional",
      "template": "dependency-audit.md",
      "create_tasks_validation": "none",
      "triggers": {
        "keywords": ["dependency", "package", "library", "npm", "pip", "cargo", "license", "supply chain", "third-party", "new dependency", "upgrade"],
        "description": "Tickets introducing new dependencies or significantly upgrading existing ones"
      }
    }
  }
}
